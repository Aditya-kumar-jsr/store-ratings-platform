{
  "name": "store-ratings-backend",
  "version": "1.0.0",
  "description": "Backend API for the store ratings platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "start:prod": "node dist/db/seed.js && node dist/index.js",
    "migrate": "ts-node-dev --transpile-only src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "seed": "ts-node-dev --transpile-only src/db/seed.ts",
    "seed:prod": "node dist/db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
